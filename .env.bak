# Thor Memecoin Sniping Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED - Bot will not start without these
# ============================================================================

# Your Solana wallet private key (base58 encoded)
# ⚠️  KEEP THIS SECRET! Never commit the actual .env file to git!
THOR_WALLET_PRIVATE_KEY=133,153,166,204,109,77,88,14,209,14,137,118,87,127,94,246,154,178,178,117,89,82,202,205,147,167,174,178,46,40,185,59,198,249,132,141,18,158,120,45,153,248,22,100,227,226,49,184,199,44,25,3,128,204,140,175,185,140,224,248,86,186,146,115

# Your Solana wallet public address
THOR_WALLET_ADDRESS=EPiQ93niowXraoGVuZ3jFz6328kDs8FedS8KKu8r2ici

# Solana RPC endpoint (mainnet-beta for live trading)
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# ============================================================================
# OPTIONAL - Trading Configuration
# ============================================================================

# Maximum position size in USD (default: 1000)
THOR_MAX_POSITION_SIZE=100

# Default slippage tolerance (default: 0.02 = 2%)
THOR_DEFAULT_SLIPPAGE=0.02

# Stop loss percentage (default: 0.15 = 15%)
THOR_STOP_LOSS_PERCENT=0.15

# Take profit percentage (default: 0.50 = 50%)
THOR_TAKE_PROFIT_PERCENT=0.50

# ============================================================================
# JITO MEV CONFIGURATION - Faster Transaction Execution
# ============================================================================

# Enable Jito MEV bundles for 40-60x faster execution (default: true)
# Jito bundles land in ~0.05s vs regular RPC ~2-3s
THOR_USE_JITO=true

# Jito tip amount in SOL (default: 0.001 = ~$0.10)
# Higher tips = higher priority = faster landing
# Recommended for sniping: 0.006 SOL
THOR_JITO_TIP=0.001

# Jito priority level: min, low, medium, high, aggressive (default: medium)
# min=0.00001 SOL, low=0.0001, medium=0.001, high=0.006, aggressive=0.01
THOR_JITO_PRIORITY=medium

# ============================================================================
# TOKEN SAFETY / CONTRACT ANALYSIS
# ============================================================================

# Enable on-chain contract analysis (default: true)
# Checks for mint authority, freeze authority, holder concentration
THOR_ENABLE_CONTRACT_ANALYSIS=true

# Minimum safety score to trade (0-100, default: 50)
# Higher = more conservative
THOR_MIN_SAFETY_SCORE=50

# Skip tokens with mint authority (can print infinite tokens)
THOR_SKIP_MINT_AUTHORITY=true

# Skip tokens with freeze authority (can freeze your wallet)
THOR_SKIP_FREEZE_AUTHORITY=true

# ============================================================================
# TRAILING STOP LOSS CONFIGURATION
# ============================================================================

# Enable trailing stop loss (locks in profit as price rises)
THOR_ENABLE_TRAILING_STOP=true

# Trailing distance % below peak price (default: 0.15 = 15%)
THOR_TRAILING_DISTANCE=0.15

# Minimum profit % before activating trailing stop (default: 0.25 = 25%)
THOR_TRAILING_ACTIVATION_PROFIT=0.25

# Use adaptive trailing (adjusts based on volatility)
THOR_USE_ADAPTIVE_TRAILING=false

# Use tiered trailing (tightens as profit increases)
THOR_USE_TIERED_TRAILING=true

# ============================================================================
# DCA (DOLLAR-COST AVERAGING) MODE
# ============================================================================

# Enable DCA for large positions (splits orders to reduce slippage)
THOR_ENABLE_DCA=false

# Default number of DCA orders (default: 5)
THOR_DCA_NUM_ORDERS=5

# Seconds between DCA orders (default: 30)
THOR_DCA_INTERVAL_SECONDS=30

# Minimum position size to trigger DCA in SOL (default: 1.0)
THOR_DCA_MIN_POSITION_SIZE=1.0

# Use smart DCA (adjusts based on price action)
THOR_USE_SMART_DCA=true

# ============================================================================
# COPY TRADING / WALLET TRACKING
# ============================================================================

# Enable wallet tracking (copy successful traders)
THOR_ENABLE_WALLET_TRACKING=false

# Auto-copy trades from tracked wallets
THOR_AUTO_COPY_TRADES=false

# Percentage of tracked wallet's position size to copy (default: 0.5 = 50%)
THOR_COPY_PERCENTAGE=0.5

# Comma-separated list of wallet addresses to track
# Example: wallet1,wallet2,wallet3
THOR_TRACKED_WALLETS=

# ============================================================================
# PRE-MARKET SNIPING / MEMPOOL MONITORING
# ============================================================================

# Enable mempool monitoring for new listings (advanced)
THOR_ENABLE_MEMPOOL_MONITOR=false

# Auto-snipe new listings detected in mempool
THOR_AUTO_SNIPE_NEW_LISTINGS=false

# Amount to spend per snipe in SOL (default: 0.1)
THOR_SNIPE_AMOUNT_SOL=0.1

# Minimum initial liquidity to snipe (default: 5.0 SOL)
THOR_SNIPE_MIN_LIQUIDITY=5.0

# Maximum initial liquidity to snipe (default: 1000.0 SOL)
THOR_SNIPE_MAX_LIQUIDITY=1000.0

# Monitor Raydium pools for new listings
THOR_MONITOR_RAYDIUM=true

# Monitor Jito mempool (requires Jito access)
THOR_MONITOR_JITO_MEMPOOL=false

# ============================================================================
# MULTI-WALLET SUPPORT
# ============================================================================

# Enable multi-wallet rotation (diversification & anonymity)
THOR_ENABLE_MULTI_WALLET=false

# Wallet rotation strategy: round_robin, random, balance_based
THOR_WALLET_ROTATION_STRATEGY=round_robin

# Auto-rotate wallet after N trades (default: 10)
THOR_ROTATE_AFTER_TRADES=10

# Additional wallet private keys (comma-separated, base58 encoded)
# These wallets will be added to rotation pool
THOR_ADDITIONAL_WALLETS=

# ============================================================================
# SOCIAL SENTIMENT TRACKING
# ============================================================================

# Enable Twitter/X sentiment tracking (requires API access)
THOR_ENABLE_SENTIMENT_TRACKING=false

# Twitter API Bearer Token (optional)
TWITTER_API_BEARER_TOKEN=

# Minimum sentiment score to trade (-1 to 1, default: 0.2)
THOR_MIN_SENTIMENT_SCORE=0.2

# ============================================================================
# OPTIONAL - API Keys (most are not required, but enhance features)
# ============================================================================

# Birdeye API (optional, has free tier)
BIRDEYE_API_KEY=

# CoinGecko API (optional, free tier available)
COINGECKO_API_KEY=

# Rugcheck API (optional)
RUGCHECK_API_KEY=

# Bubblemaps API (optional)
BUBBLEMAPS_API_KEY=

# Moni Score API (optional)
MONI_API_KEY=

# ============================================================================
# PUBLIC APIs (no keys needed)
# ============================================================================
# - Dexscreener: Public API
# - Pump.fun: Public API
# - GMGN.ai: Public API
# - Jupiter: Public API
# - Raydium: Public API

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. NEVER share your private key with anyone
# 2. NEVER commit your .env file to version control
# 3. START WITH SMALL POSITION SIZES to test
# 4. This is LIVE TRADING - real money will be used
# 5. The bot will execute trades automatically based on filters
# 6. Use at your own risk - crypto trading is highly risky
# ============================================================================
