# Thor Memecoin Sniping Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED - Bot will not start without these
# ============================================================================

# Your Solana wallet private key (base58 encoded)
# ⚠️  KEEP THIS SECRET! Never commit the actual .env file to git!
THOR_WALLET_PRIVATE_KEY=your_private_key_here

# Your Solana wallet public address
THOR_WALLET_ADDRESS=your_wallet_address_here

# Solana RPC endpoint (mainnet-beta for live trading)
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# ============================================================================
# OPTIONAL - Trading Configuration
# ============================================================================

# Maximum position size in USD (default: 1000)
THOR_MAX_POSITION_SIZE=100

# Default slippage tolerance (default: 0.02 = 2%)
THOR_DEFAULT_SLIPPAGE=0.02

# ============================================================================
# OPTIONAL - API Keys (most are not required, but enhance features)
# ============================================================================

# Birdeye API (optional, has free tier)
BIRDEYE_API_KEY=

# CoinGecko API (optional, free tier available)
COINGECKO_API_KEY=

# Rugcheck API (optional)
RUGCHECK_API_KEY=

# Bubblemaps API (optional)
BUBBLEMAPS_API_KEY=

# Moni Score API (optional)
MONI_API_KEY=

# ============================================================================
# PUBLIC APIs (no keys needed)
# ============================================================================
# - Dexscreener: Public API
# - Pump.fun: Public API
# - GMGN.ai: Public API
# - Jupiter: Public API
# - Raydium: Public API

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. NEVER share your private key with anyone
# 2. NEVER commit your .env file to version control
# 3. START WITH SMALL POSITION SIZES to test
# 4. This is LIVE TRADING - real money will be used
# 5. The bot will execute trades automatically based on filters
# 6. Use at your own risk - crypto trading is highly risky
# ============================================================================
